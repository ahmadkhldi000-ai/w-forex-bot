// ====================================================================
//  W-FOREX-BOT · Prisma Schema
//  Database: PostgreSQL
//  ====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------------
//  ENUMS
// --------------------------------------------------------------------

enum UserRole {
  USER
  VIP
  PREMIUM
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
  PENDING
}

// How a user authenticates (email/password vs. OAuth providers)
enum AccountProvider {
  LOCAL     // email + password
  GOOGLE    // Google OAuth
}

enum SubscriptionTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
  VIP
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
  TRIALING
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  EXPIRED
}

enum PaymentMethod {
  USDT_TRC20
  USDT_ERC20
  BTC
  ETH
  TRX
}

enum BillingCycle {
  MONTHLY
  YEARLY
  LIFETIME
}

enum TradeType {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
  PENDING
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

enum Permission {
  // Users
  USERS_VIEW
  USERS_MANAGE
  // Subscriptions
  SUBS_VIEW
  SUBS_MANAGE
  // Payments
  PAYMENTS_VIEW
  PAYMENTS_MANAGE
  // Bot
  BOT_VIEW
  BOT_MANAGE
  // MT5
  MT5_VIEW
  MT5_MANAGE
  // Settings
  SETTINGS_VIEW
  SETTINGS_MANAGE
  // Notifications
  NOTIFS_MANAGE
  // Reports
  REPORTS_VIEW
  REPORTS_EXPORT
  // Audit Logs
  LOGS_VIEW
  LOGS_EXPORT
  // Admins (super admin only)
  ADMINS_MANAGE
}

enum LogAction {
  LOGIN
  LOGOUT
  REGISTER
  CREATE
  UPDATE
  DELETE
  PAYMENT
  SUBSCRIPTION_CHANGE
  RISK_CONSENT
  BOT_ACTION
  MT5_ACTION
  SETTINGS_CHANGE
  FAILED_LOGIN
  EXPORT
}

// --------------------------------------------------------------------
//  USER MODEL
// --------------------------------------------------------------------

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String? // nullable for OAuth-only accounts
  name         String?
  phone        String?
  avatarUrl    String?

  // OAuth / identity provider
  provider    AccountProvider @default(LOCAL)
  providerId  String?         // Google sub id
  @@unique([provider, providerId])

  role   UserRole   @default(USER)
  status UserStatus @default(PENDING)

  // Risk consent (click-through agreement)
  riskAccepted   Boolean   @default(false)
  riskAcceptedAt DateTime?
  riskAcceptedIp String?

  // Email verification & 2FA
  emailVerified    Boolean @default(false)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Copy trading settings
  copyTradingEnabled Boolean @default(false)
  copyRiskPercent    Float   @default(2) @db.Real
  copyMaxLeverage    Int     @default(30)
  copyLotSize        Float   @default(0.01) @db.Real

  // MT5 connection (encrypted at rest by app layer)
  mt5Login       String?
  mt5PasswordEnc String? // AES-256 encrypted
  mt5Server      String?

  // Subscription relation
  subscriptions Subscription[]

  // Relations
  payments      Payment[]
  invoices      Invoice[]
  trades        Trade[]
  sessions      Session[]
  notifications Notification[]
  auditLogs     AuditLog[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  lastLoginIp String?

  @@index([email])
  @@index([status])
  @@map("users")
}

// --------------------------------------------------------------------
//  ADMIN MODEL (separate table from users — as per spec)
// --------------------------------------------------------------------

model Admin {
  id           String @id @default(cuid())
  email        String @unique
  username     String @unique
  passwordHash String

  name        String?
  role        AdminRole    @default(ADMIN)
  permissions Permission[]

  // Security
  twoFactorEnabled    Boolean @default(false)
  twoFactorSecret     String?
  forcePasswordChange Boolean @default(true) // must change on first login

  // IP whitelist
  ipWhitelist String[] @default([])

  // Account lockout
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  // Session control
  sessions  AdminSession[]
  auditLogs AuditLog[]

  // SSO
  googleId String?
  githubId String?

  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  newDeviceNotifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("admins")
}

// --------------------------------------------------------------------
//  SESSIONS
// --------------------------------------------------------------------

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model AdminSession {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([adminId])
  @@map("admin_sessions")
}

// --------------------------------------------------------------------
//  SUBSCRIPTIONS
// --------------------------------------------------------------------

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier         SubscriptionTier   @default(FREE)
  status       SubscriptionStatus @default(TRIALING)
  billingCycle BillingCycle       @default(MONTHLY)

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("USD")

  startDate   DateTime
  endDate     DateTime
  cancelledAt DateTime?

  // Coupon
  couponCode      String?
  discountPercent Float   @default(0) @db.Real

  // Related payments
  payments Payment[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

// --------------------------------------------------------------------
//  PAYMENTS (Paymento integration)
// --------------------------------------------------------------------

model Payment {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  // Paymento
  paymentoToken String? @unique // token from Paymento step 2
  paymentoTxId  String? @unique // transaction id from Paymento

  amount   Decimal        @db.Decimal(12, 2)
  currency String         @default("USD")
  method   PaymentMethod?
  status   PaymentStatus  @default(PENDING)

  // Guest checkout
  guestEmail String?

  // Webhook tracking
  ipnReceived Boolean @default(false)
  ipnVerified Boolean @default(false)
  ipnPayload  Json? // raw payload for audit

  description String?
  invoiceUrl  String?

  // USDT TRC-20 payment tracking
  depositAddress String? // TRC-20 wallet address to receive payment
  cryptoNetwork  String? @default("TRC20") // TRC20, ERC20, etc.
  cryptoAmount  Decimal? @db.Decimal(18, 6) // amount in crypto (USDT)
  txHash        String? // on-chain transaction hash
  confirmations Int    @default(0) // blockchain confirmations
  paymentWindowExpires DateTime? // countdown deadline for pending payment

  invoices Invoice[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([paymentoTxId])
  @@index([depositAddress])
  @@index([txHash])
  @@map("payments")
}

// --------------------------------------------------------------------
//  INVOICES
// --------------------------------------------------------------------

model Invoice {
  id          String   @id @default(cuid())
  number      String   @unique // sequential: INV-2026-0001
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  paymentId   String?
  payment     Payment? @relation(fields: [paymentId], references: [id])

  // Line items
  tier         String
  billingCycle String
  subtotal     Decimal @db.Decimal(12, 2)
  discount     Decimal @db.Decimal(12, 2) @default(0)
  tax          Decimal @db.Decimal(12, 2) @default(0)
  total        Decimal @db.Decimal(12, 2)

  currency   String  @default("USD")
  status     InvoiceStatus @default(PENDING)

  // Billing details
  customerName  String?
  customerEmail String?
  notes         String?

  issueDate    DateTime @default(now())
  dueDate      DateTime
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  VOID
  REFUNDED
}

// --------------------------------------------------------------------
//  TRADES (real-time from MT5)
// --------------------------------------------------------------------

model Trade {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // MT5
  mt5Ticket  BigInt    @unique
  mt5Login   String
  symbol     String
  type       TradeType
  volume     Float     @db.Real
  openPrice  Float     @db.DoublePrecision
  closePrice Float?    @db.DoublePrecision
  sl         Float?    @db.DoublePrecision
  tp         Float?    @db.DoublePrecision

  profit     Float @default(0) @db.DoublePrecision
  swap       Float @default(0) @db.DoublePrecision
  commission Float @default(0) @db.DoublePrecision
  netProfit  Float @default(0) @db.DoublePrecision

  status      TradeStatus @default(OPEN)
  isCopyTrade Boolean     @default(false)

  openTime  DateTime
  closeTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([symbol])
  @@index([status])
  @@index([mt5Login])
  @@map("trades")
}

// --------------------------------------------------------------------
//  NOTIFICATIONS
// --------------------------------------------------------------------

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String // payment, subscription, trade, system, risk
  title   String
  message String
  isRead  Boolean @default(false)
  data    Json?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// --------------------------------------------------------------------
//  AUDIT LOGS (compliance — all admin & user actions)
// --------------------------------------------------------------------

model AuditLog {
  id      String  @id @default(cuid())
  userId  String?
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  adminId String?
  admin   Admin?  @relation(fields: [adminId], references: [id], onDelete: SetNull)

  action     LogAction
  resource   String? // e.g. "user", "payment", "subscription"
  resourceId String?

  ipAddress String?
  userAgent String?
  details   Json? // before/after diff or extra context

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// --------------------------------------------------------------------
//  PLATFORM SETTINGS (managed by admin)
// --------------------------------------------------------------------

model Setting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  type        String  @default("string") // string, number, boolean, json
  category    String  @default("general")
  description String?
  isPublic    Boolean @default(false)

  updatedAt DateTime @updatedAt
  updatedBy String? // adminId

  @@map("settings")
}

// --------------------------------------------------------------------
//  COUPONS
// --------------------------------------------------------------------

model Coupon {
  id              String            @id @default(cuid())
  code            String            @unique
  description     String?
  discountPercent Float             @db.Real
  maxUses         Int               @default(-1) // -1 = unlimited
  usedCount       Int               @default(0)
  validFrom       DateTime          @default(now())
  validUntil      DateTime?
  isActive        Boolean           @default(true)
  appliedTo       SubscriptionTier?

  createdAt DateTime @default(now())

  @@map("coupons")
}

// --------------------------------------------------------------------
//  MEMBERSHIP PLANS (configurable pricing)
// --------------------------------------------------------------------

model Plan {
  id          String           @id @default(cuid())
  tier        SubscriptionTier @unique
  name        String
  description String?

  priceMonthly Decimal @db.Decimal(12, 2)
  priceYearly  Decimal @db.Decimal(12, 2)
  currency     String  @default("USD")

  // Limits
  maxAccounts Int   @default(1)
  maxLotSize  Float @default(0.01) @db.Real
  maxLeverage Int   @default(30)
  features    Json // array of feature strings

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

// --------------------------------------------------------------------
//  MT5 MASTER ACCOUNT MANAGEMENT
//  Multiple MT5 accounts supported; exactly one is "active" (trading)
//  and one is the "master" (copy-trading source) at any time.
//  Uniqueness of active/master is enforced at the service layer.
// --------------------------------------------------------------------

enum MT5Server {
  METAQUOTES_DEMO
  METAQUOTES_REAL
  ICMARKETS_DEMO
  ICMARKETS_REAL
  PEPPERSTONE_DEMO
  PEPPERSTONE_REAL
  CUSTOM
}

model MT5Account {
  id String @id @default(cuid())

  label      String // friendly name, e.g. "Main Prop Firm"
  login      String // MT5 login (account number)
  server     MT5Server @default(METAQUOTES_DEMO)
  serverName String? // raw server string when CUSTOM

  // Credentials are stored ENCRYPTED at the service layer, never plaintext.
  passwordEnc String

  // Trading profile
  currency String @default("USD")
  leverage Int    @default(100)
  balance  Float  @default(0) @db.Real
  equity   Float  @default(0) @db.Real

  // State — exactly one active & one master system-wide (enforced in code)
  isActive     Boolean @default(false)
  isMaster     Boolean @default(false)
  isActiveConn Boolean @default(false) // live bridge connected?

  // Audit
  createdBy       String? // adminId
  lastConnectedAt DateTime?
  lastError       String?

  // Live fields updated by the Web Connector (MT5 EA)
  broker      String?
  serverRaw   String?
  margin      Float   @default(0) @db.Real
  drawdown    Float   @default(0) @db.Real
  drawdownPct Float   @default(0) @db.Real

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  performances  Performance[]
  connectorLogs ConnectorLog[]
  apiKeys       ApiKey[]

  @@index([isActive])
  @@index([isMaster])
  @@index([login])
  @@map("mt5_accounts")
}

// --------------------------------------------------------------------
//  PERFORMANCE SNAPSHOT
//  One row per account snapshot pushed by the Web Connector.
//  Used to build equity curves, drawdown charts, and rolling stats.
// --------------------------------------------------------------------
model Performance {
  id           String     @id @default(cuid())
  mt5AccountId String
  account      MT5Account @relation(fields: [mt5AccountId], references: [id], onDelete: Cascade)

  balance     Float @db.Real
  equity      Float @db.Real
  margin      Float @db.Real
  drawdown    Float @default(0) @db.Real
  drawdownPct Float @default(0) @db.Real

  openTrades  Int   @default(0)
  totalTrades Int   @default(0)
  wins        Int   @default(0)
  losses      Int   @default(0)
  winRate     Float @default(0) @db.Real
  realizedPnl Float @default(0) @db.Real
  floatingPnl Float @default(0) @db.Real

  snapshotTime DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([mt5AccountId])
  @@index([snapshotTime])
  @@map("performance_snapshots")
}

// --------------------------------------------------------------------
//  CONNECTOR LOG
//  Lightweight event log for the MT5 Web Connector — every ingest
//  cycle and every auth failure is recorded here.
// --------------------------------------------------------------------
model ConnectorLog {
  id           String      @id @default(cuid())
  mt5AccountId String?
  account      MT5Account? @relation(fields: [mt5AccountId], references: [id], onDelete: SetNull)

  level     ConnectorLogLevel @default(INFO)
  event     String // account | trade_open | trade_modify | trade_close | full_sync | connection | auth_failed
  message   String
  source    String            @default("web_connector")
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([mt5AccountId])
  @@index([event])
  @@index([createdAt])
  @@index([level])
  @@map("connector_logs")
}

enum ConnectorLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// --------------------------------------------------------------------
//  API KEYS (Web Connector authentication)
//  The MT5 EA presents the raw key in the X-API-Key header; the server
//  stores a SHA-256 hash and does a constant-time comparison.
// --------------------------------------------------------------------
model ApiKey {
  id           String      @id @default(cuid())
  name         String // friendly label, e.g. "Main EA"
  keyHash      String      @unique // sha256(rawKey)
  keyPrefix    String // first 8 chars for display
  scope        ApiKeyScope @default(MT5_INGEST)
  mt5AccountId String?
  account      MT5Account? @relation(fields: [mt5AccountId], references: [id], onDelete: SetNull)

  isActive     Boolean   @default(true)
  lastUsedAt   DateTime?
  requestCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([keyHash])
  @@map("api_keys")
}

enum ApiKeyScope {
  MT5_INGEST
  READ_ONLY
  FULL_ACCESS
}
