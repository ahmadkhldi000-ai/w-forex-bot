# ====================================================================
#  W-FOREX-BOT · MT5 Bridge Environment Variables
#  Copy this file to .env and fill in your values
#  This file stays on your LOCAL PC only — never committed to git
#  ====================================================================

# ---- MT5 Account (local only — never sent to server) ----
# Your MetaTrader 5 terminal login (account number)
MT5_LOGIN=12345678
# MT5 password (used only by this local script to connect to your terminal)
MT5_PASSWORD=your-mt5-password
# MT5 server name (shown in your broker's terminal)
MT5_SERVER=YourBroker-Server

# ---- API Server ----
# Your Render backend URL (or http://localhost:4000 for local dev)
SERVER_URL=https://w-forex-bot-api.onrender.com
# The connector secret/API key.
# IMPORTANT: This must match the CONNECTOR_API_KEYS value set on the server.
BRIDGE_SECRET=change-me

# ---- Polling ----
# How often to read positions from MT5 (seconds)
POLL_INTERVAL=1.0
